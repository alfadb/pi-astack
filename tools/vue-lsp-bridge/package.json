{
  "name": "@alfadb/pi-astack-vue-lsp-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "Standard LSP bridge from pi-lsp to Vue language-server hybrid mode",
  "type": "module",
  "bin": {
    "pi-vue-lsp-bridge": "bin/pi-vue-lsp-bridge.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:child-failure": "PI_VUE_LSP_TEST_EXIT_CHILD=tls node test/real-vue-smoke.js",
    "smoke": "node test/real-vue-smoke.js"
  },
  "dependencies": {
    "@vue/language-server": "3.3.8",
    "@vue/typescript-plugin": "3.3.8",
    "typescript": "6.0.3",
    "typescript-language-server": "5.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
